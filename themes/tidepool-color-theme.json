  "semanticTokenColors": {
    "keyword": "#4FB0C2",
    "type": "#6FC9DA",
    "class": "#6FC9DA",
    "interface": "#6FC9DA",
    "enum": "#6FC9DA",
    "typeParameter": "#6FC9DA",
    "namespace": "#6FC9DA",
